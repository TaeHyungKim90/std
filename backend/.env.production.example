# Backend production environment template
#
# 실제 운영 값은 인프라(Secret Manager, CI/CD, 서버 환경 변수 등)에 설정하고,
# 이 파일은 "어떤 값이 필요한지" 문서 겸 샘플로만 사용하세요.

# --- 필수 보안 키 ---
SECRET_KEY=replace-with-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=1

# --- 데이터베이스 ---
# 예시) postgresql+psycopg2://user:pass@db-host:5432/todo
DATABASE_URL=postgresql+psycopg2://user:pass@db-host:5432/todo

# --- OAuth / 소셜 로그인 (법인용) ---
KAKAO_CLIENT_ID=corp-kakao-client-id
KAKAO_CLIENT_SECRET=corp-kakao-client-secret
KAKAO_REDIRECT_URI=https://api.your-company.com/api/auth/kakao/callback

NAVER_CLIENT_ID=corp-naver-client-id
NAVER_CLIENT_SECRET=corp-naver-client-secret
NAVER_REDIRECT_URI=https://api.your-company.com/api/auth/naver/callback

# --- 공공데이터포털(법인 키) ---
PUBLIC_DATA_API_KEY=your-data-go-kr-encoded-key
HOLIDAY_API_URL=https://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService/getRestDeInfo

# --- 환경/오리진 ---
ENVIRONMENT=production
# 쉼표로 구분된 허용 오리진(프론트 도메인)
CORS_ORIGINS=https://hr.your-company.com,https://careers.your-company.com
# 프론트엔드 SPA 진입점(소셜 로그인 콜백 등에서 사용)
FRONTEND_URL=https://hr.your-company.com

# --- 운영 옵션 ---
BOOTSTRAP_DEFAULT_ADMIN=false
SERVE_UPLOADS_STATIC=false
DEV_AUTO_START_REACT=false

# 레거시 공개 지원서 제출(/apply) 허용 여부 — 운영에서는 false
ALLOW_LEGACY_PUBLIC_APPLY=false
# 레거시 지원자 API(/update/{id}, /my-applications/{id}) 허용 여부 — 운영에서는 false
ALLOW_LEGACY_APPLICANT_ID_ENDPOINTS=false

