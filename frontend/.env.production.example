# Frontend (React) production environment template
#
# CRA 규칙상 REACT_APP_ 접두사가 붙은 값만 브라우저에 노출됩니다.
# 실제 운영 값은 인프라(Secret Manager, CI/CD, 호스팅 환경 변수 등)에 설정하고,
# 이 파일은 참고용 샘플로만 사용하세요.

# FastAPI 백엔드의 /api 프리픽스까지 포함한 풀 URL
# 예시) https://api.your-company.com/api
# 비어 있으면 `npm run build` 시 scripts/verify-production-env.js 가 실패합니다.
REACT_APP_API_BASE_URL=https://api.your-company.com/api

# 첨부파일 다운로드 방식을 제어 (기본: API 경유 true)
# REACT_APP_FILE_DOWNLOAD_VIA_API=true

