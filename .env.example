# In a real application, get these values from your Google Cloud project
# and create a .env file with them.
# DO NOT commit the .env file to version control.

# Generate a strong secret key. You can use the following command:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your_super_secret_key_generated_with_openssl_or_python"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# These are placeholder values.
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://127.0.0.1:8000/auth/google/callback"
