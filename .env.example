# 프로젝트 루트에 복사: copy .env.example .env  후 값 채우기. .env 는 커밋하지 마세요.

# --- 필수 ---
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=1

# 소셜 로그인 (미사용 시 더미라도 pydantic이 요구하면 채움)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8000/api/auth/naver/callback

PUBLIC_DATA_API_KEY=일반 인증키(Decoding)
HOLIDAY_API_URL=End Point 주소

ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# DB (비우면 SQLite 기본)
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost/todo

BOOTSTRAP_DEFAULT_ADMIN=false

# --- 보안·운영 옵션 ---
# True: /uploads 를 브라우저에서 직접 열 수 있음. 운영에서는 False 권장 + /api/common/files/{id} 사용
SERVE_UPLOADS_STATIC=true
# True: python backend/app/main.py 실행 시 CRA(npm start) 자동 기동. CI/운영에서는 False
DEV_AUTO_START_REACT=false

# --- 채용(지원자) 보안 옵션 ---
# 레거시 공개 지원서 제출(/api/public/recruitment/apply) 허용 여부.
# 운영에서는 False 권장(지원자 쿠키 세션 기반 /apply/me만 사용).
ALLOW_LEGACY_PUBLIC_APPLY=true

# 레거시 지원자 API(/update/{applicant_id}, /my-applications/{applicant_id} 등) 허용 여부.
# 운영에서는 False 권장(지원자 /me 기반 API만 사용).
ALLOW_LEGACY_APPLICANT_ID_ENDPOINTS=true

# --- 프론트(frontend/.env) 예시 ---
# REACT_APP_API_BASE_URL=http://localhost:8000/api
# SERVE_UPLOADS_STATIC=false 일 때 첨부 열기는 API 사용(기본). 직접 /uploads 쓰려면:
# REACT_APP_FILE_DOWNLOAD_VIA_API=false
