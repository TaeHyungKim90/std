SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=1
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Kakao OAuth (FastAPI 라우터 prefix: /api)
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/kakao/callback

# Naver OAuth
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:8000/api/auth/naver/callback

# Public Data API
PUBLIC_DATA_API_KEY=your_public_data_api_key

# development | production — 운영에서는 production 권장
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# DB: 비우면 backend/app/todo.db SQLite 사용. PostgreSQL 예시:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/todo

# 로컬 개발만 true — 약한 기본 관리자(admin/1234) 1회 생성. 운영에서는 반드시 false
BOOTSTRAP_DEFAULT_ADMIN=true