# Python 관련
__pycache__/
*.pyc
venv/
.venv/
env/

# FastAPI / DB 관련
.env
*.db
*.sqlite3

# Node.js / React 관련
node_modules/
**/node_modules/.cache/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/frontend/build/
/frontend/dist/
/mobile-app
# 에디터 및 OS 관련
.vscode/
.idea/
.DS_Store
Thumbs.db
# 모든 업로드 파일 무시
static/uploads/*

# 하지만 .gitkeep 파일은 제외 (폴더 구조 유지를 위해)
!static/uploads/.gitkeep