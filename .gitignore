# Python 관련
__pycache__/
*.pyc
venv/
.venv/
env/

# FastAPI / DB 관련
.env
*.db
*.sqlite3

# Node.js / React 관련
node_modules/
**/node_modules/.cache/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/frontend/build/
/frontend/dist/
/mobile-app
# 에디터 및 OS 관련
.vscode/
.idea/
.DS_Store
Thumbs.db
# 운영 프론트 빌드 산출물(static) 무시
/static/*
!/static/index.html

# 업로드 폴더는 유지하되 파일은 무시
!/static/uploads/
/static/uploads/*

# 폴더 구조 유지를 위한 .gitkeep만 추적
!/static/uploads/.gitkeep